{
    "version": "2.0.0",
    "options": {
        "env": {
            "LANG": "C.UTF-8",
            "LC_ALL": "C.UTF-8"
        }
    },
    "tasks": [
        {
            "label": "build-tests",
            "type": "shell",
            "command": "VERBOSE=1 CXXFLAGS=\"-gdwarf-4\" WITH_OPENMP=0 make ./build/tests/tests -j$(perl script/sys-get-nproc.pl)",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build-single-file",
            "type": "shell",
            "command": "g++ -std=c++20 -Wall -pedantic -DNO_CATCH_MAIN -fopenmp -g -O0 ${file} -o ${fileDirname}/${fileBasenameNoExtension}",
            "group": "build"
        }
    ]
}
