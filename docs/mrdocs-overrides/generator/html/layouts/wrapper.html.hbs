<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
{{#if @root.config.multipage }}
<title>{{#if symbol.name}}{{symbol.name}} | {{/if}}Epiworld API</title>
{{else}}
<title>Epiworld API</title>
{{/if}}
<meta name="description" content="Generated C++ API reference for epiworld.">
<script>
(() => {
  const marker = '/api/reference/';
  const pathname = window.location.pathname;
  const markerIndex = pathname.indexOf(marker);
  const siteRoot = markerIndex >= 0 ? pathname.slice(0, markerIndex + 1) : '/';

  const joinSitePath = (relativePath) => {
    const base = siteRoot.endsWith('/') ? siteRoot : `${siteRoot}/`;
    return `${base}${String(relativePath).replace(/^\/+/, '')}`;
  };

  const appendStylesheet = (relativePath) => {
    const element = document.createElement('link');
    element.rel = 'stylesheet';
    element.href = joinSitePath(relativePath);
    document.head.appendChild(element);
  };

  const appendIcon = (relativePath) => {
    const element = document.createElement('link');
    element.rel = 'icon';
    element.href = joinSitePath(relativePath);
    document.head.appendChild(element);
  };

  const appendScript = (relativePath) => {
    const element = document.createElement('script');
    element.defer = true;
    element.src = joinSitePath(relativePath);
    document.head.appendChild(element);
  };

  const applyWrapperPaths = () => {
    document.querySelectorAll('[data-site-path]').forEach((element) => {
      element.setAttribute('href', joinSitePath(element.dataset.sitePath));
    });
    document.querySelectorAll('[data-site-src]').forEach((element) => {
      element.setAttribute('src', joinSitePath(element.dataset.siteSrc));
    });
  };

  appendIcon('assets/branding/epiworld.png');
  appendStylesheet('stylesheets/extra.css');
  appendScript('javascripts/site.js');

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', applyWrapperPaths, { once: true });
  } else {
    applyWrapperPaths();
  }
})();
</script>
</head>
<body class="epiworld-docs page-api-reference">
<header class="site-header">
  <div class="site-header-inner">
    <a class="site-brand" data-site-path="index.html" href="#">
      <img data-site-src="assets/branding/epiworld.png" alt="Epiworld logo">
      <span>Epiworld Docs</span>
    </a>
    <button class="site-nav-toggle" type="button" aria-expanded="false" aria-controls="site-sidebar">Menu</button>
    <nav class="site-topnav" aria-label="Primary">
      <a data-site-path="index.html" href="#">Home</a>
      <a data-site-path="models/index.html" href="#">Models</a>
      <a data-site-path="api/index.html" href="#">API</a>
      <a data-site-path="impl/index.html" href="#">Implementation</a>
      <a href="https://github.com/UofUEpiBio/epiworld">GitHub</a>
    </nav>
  </div>
</header>
<div class="site-layout">
  <aside class="site-sidebar" id="site-sidebar">
    <nav class="site-sidebar-nav" aria-label="Documentation">
      <div class="site-sidebar-group">
        <p class="site-sidebar-heading">Sections</p>
        <ul>
          <li><a data-site-path="index.html" href="#">Home</a></li>
          <li><a data-site-path="models/index.html" href="#">Models</a></li>
          <li class="is-active"><a data-site-path="api/index.html" href="#">API Reference</a></li>
          <li><a data-site-path="impl/index.html" href="#">Implementation</a></li>
        </ul>
      </div>
      <div class="site-sidebar-group">
        <p class="site-sidebar-heading">API</p>
        <ul>
          <li><a data-site-path="api/index.html" href="#">Overview</a></li>
          <li><a data-site-path="api/reference/index.html" href="#">Reference Index</a></li>
        </ul>
      </div>
    </nav>
  </aside>
  <main class="site-main">
    <article class="content-card api-reference-card">
      {{{contents}}}
    </article>
  </main>
</div>
<footer class="site-footer">
  <div class="site-footer-inner">
    <p>Built with MrDocs for the generated C++ reference.</p>
    <a href="https://github.com/UofUEpiBio/epiworld">UofUEpiBio/epiworld</a>
  </div>
</footer>
</body>
</html>
