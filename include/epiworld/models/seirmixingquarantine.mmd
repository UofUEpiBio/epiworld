flowchart TB

    %% Disease progression states
    subgraph Main[Disease Progression]
        direction TB
        S[Susceptible]
        E[Exposed]
        In[Infected]
        H[Hospitalized]
        R[Recovered]
    end

    S --> E
    E --> In
    In --> H
    H --> R
    In --> R

    %% Quarantine states
    Qs[Quarantined<br>Susceptible]
    Qe[Quarantined<br>Exposed]
    I[Isolated]
    Ir[Isolated<br>Recovered]

    %% Infected to
    In <==> I
    In --> Ir
    In --> H

    %% Isolated to
    I --> R
    I --> Ir
    I --> H

    %% Susceptible quarantined
    S <==> Qs

    %% Exposed
    E <==> Qe

    Qe --> I
    Qe --> In

    %% Isolated recovered
    Ir --> R
    